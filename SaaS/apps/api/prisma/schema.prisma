generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  psychologist
  psychiatrist
  counsellor
  admin
}

enum Theme {
  light
  dark
}

enum SessionType {
  online
  physical
}

enum SessionStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PrescriptionStatus {
  active
  expired
  revoked
}

enum AlertCategory {
  crisis
  financial
  other
}

enum AlertStatus {
  pending
  acknowledged
  escalated
}

model User {
  id                    String          @id @default(cuid())
  name                  String
  email                 String          @unique
  hashedPassword        String
  role                  Role
  avatar                String?
  phone                 String?
  slmcRegNo             String?
  slmcCertificateDataUrl String?
  nicDocumentDataUrl    String?
  province              String?
  languages             String[]        @default([])
  timezone              String          @default("Asia/Colombo")
  theme                 Theme           @default(light)
  bio                   String?
  specialty             String?
  sessionTypes          SessionType[]   @default([])
  sealDataUrl           String?
  verified              Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  clientProfile         ClientProfile?
  clientSessions        Session[]       @relation("ClientSessions")
  practitionerSessions  Session[]       @relation("PractitionerSessions")
  clientMoodEntries     MoodEntry[]     @relation("ClientMoodEntries")
  clientGoals           Goal[]          @relation("ClientGoals")
  practitionerGoals     Goal[]          @relation("PractitionerGoals")
  sessionNotesAsClient  SessionNote[]   @relation("ClientNotes")
  sessionNotesAuthored  SessionNote[]   @relation("PractitionerNotes")
  messagesSent          Message[]       @relation("MessagesSent")
  messagesReceived      Message[]       @relation("MessagesReceived")
  keywordsCreated       KeywordAlert[]
  safetyAlertsAsClient  MessageSafetyAlert[] @relation("ClientSafetyAlerts")
  safetyAlertsAsPractitioner MessageSafetyAlert[] @relation("PractitionerSafetyAlerts")
  clientPrescriptions   Prescription[]  @relation("ClientPrescriptions")
  issuedPrescriptions   Prescription[]  @relation("PsychiatristPrescriptions")

  @@index([role, verified])
  @@index([province])
}

model ClientProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  diagnosis              String[] @default([])
  currentMedications     String[] @default([])
  emergencyContactName   String?
  emergencyContactPhone  String?
  emergencyContactRelation String?
  assignedPractitionerId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id             String        @id @default(cuid())
  clientId       String
  practitionerId String
  scheduledAt    DateTime
  duration       Int           @default(60)
  type           SessionType
  status         SessionStatus @default(pending)
  meetingLink    String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client         User          @relation("ClientSessions", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner   User          @relation("PractitionerSessions", fields: [practitionerId], references: [id], onDelete: Cascade)
  sessionNotes   SessionNote[]

  @@index([clientId, scheduledAt])
  @@index([practitionerId, scheduledAt])
}

model SessionNote {
  id             String   @id @default(cuid())
  sessionId      String
  practitionerId String
  clientId       String
  content        String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  practitioner   User     @relation("PractitionerNotes", fields: [practitionerId], references: [id], onDelete: Cascade)
  client         User     @relation("ClientNotes", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([sessionId, practitionerId])
}

model MoodEntry {
  id                     String   @id @default(cuid())
  clientId               String
  date                   DateTime
  score                  Int
  emotions               String[] @default([])
  note                   String?
  sharedWithPractitioner Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  client                 User     @relation("ClientMoodEntries", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date])
  @@index([clientId, date])
}

model Goal {
  id             String          @id @default(cuid())
  clientId       String
  practitionerId String
  title          String
  description    String?
  targetDate     DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  client         User            @relation("ClientGoals", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner   User            @relation("PractitionerGoals", fields: [practitionerId], references: [id], onDelete: Cascade)
  weeklyCheckIns WeeklyCheckIn[]

  @@index([clientId, completedAt])
}

model WeeklyCheckIn {
  id             String   @id @default(cuid())
  goalId         String
  week           DateTime
  progressRating Int
  note           String?
  createdAt      DateTime @default(now())

  goal           Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, week])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  content        String
  flagged        Boolean  @default(false)
  flagReasons    String[] @default([])
  readAt         DateTime?
  createdAt      DateTime @default(now())

  sender         User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  safetyAlerts   MessageSafetyAlert[]

  @@index([conversationId, createdAt])
  @@index([flagged, createdAt])
}

model KeywordAlert {
  id          String        @id @default(cuid())
  keyword     String        @unique
  category    AlertCategory @default(other)
  status      AlertStatus   @default(pending)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model MessageSafetyAlert {
  id             String        @id @default(cuid())
  messageId      String
  clientId       String
  practitionerId String
  reasons        String[]      @default([])
  status         AlertStatus   @default(pending)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  message        Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  client         User          @relation("ClientSafetyAlerts", fields: [clientId], references: [id], onDelete: Cascade)
  practitioner   User          @relation("PractitionerSafetyAlerts", fields: [practitionerId], references: [id], onDelete: Cascade)

  @@index([practitionerId, status, createdAt])
  @@index([clientId, createdAt])
}

model Prescription {
  id             String             @id @default(cuid())
  clientId       String
  psychiatristId String
  signatureDataUrl String
  sealDataUrl    String
  issuedAt       DateTime           @default(now())
  expiresAt      DateTime
  status         PrescriptionStatus @default(active)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  client         User               @relation("ClientPrescriptions", fields: [clientId], references: [id], onDelete: Cascade)
  psychiatrist   User               @relation("PsychiatristPrescriptions", fields: [psychiatristId], references: [id], onDelete: Cascade)
  medications    Medication[]
}

model Medication {
  id             String       @id @default(cuid())
  prescriptionId String
  name           String
  dosage         String
  frequency      String
  duration       String

  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Article {
  id        String   @id @default(cuid())
  title     String
  category  String
  desc      String
  content   String?
  readTime  String
  marker    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
